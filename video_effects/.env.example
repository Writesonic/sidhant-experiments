# Temporal
VFX_TEMPORAL_ENDPOINT=localhost:7233
VFX_TEMPORAL_NAMESPACE=default
VFX_TASK_QUEUE=video_effects_queue

# Anthropic (required for LLM features)
VFX_ANTHROPIC_API_KEY=

# LLM models
VFX_LLM_MODEL=claude-sonnet-4-6
VFX_SMALL_LLM_MODEL=claude-haiku-4-5
VFX_INFOGRAPHIC_LLM_MODEL=claude-opus-4-6
VFX_PROGRAMMER_LLM_MODEL=claude-opus-4-6

# ElevenLabs (optional — falls back to local whisper)
VFX_ELEVENLABS_API_KEY=

# AWS (optional — for S3 rendering uploads)
VFX_AWS_ACCESS_KEY_ID=
VFX_AWS_SECRET_ACCESS_KEY=
VFX_AWS_REGION=us-east-1

# Remotion
VFX_REMOTION_CONCURRENCY=8

# API server
VFX_API_PORT=8000
VFX_API_CORS_ORIGINS=["http://localhost:3000"]
